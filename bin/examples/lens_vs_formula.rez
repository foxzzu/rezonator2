        {
            "formula": "'''\nDioptric lens\n\nThis element works the same as the built-in Thin lens element\nbut allows for changing the lens's dioptric power\ninstead of its focal range.\n'''\n\nfrom math import cos\nfrom rezonator import Element, Matrix\n\ndef calc_matrix(elem: Element):\n  P = elem.param('P', 1)\n  a = elem.param('alpha', 0)\n  return {\n    'Mt': Matrix(1, 0, -P / cos(a), 1),\n    'Ms': Matrix(1, 0, -P * cos(a), 1),\n  }\n",
            "is_disabled": false,
            "label": "DL1",
            "layout_draw_alt": false,
            "layout_show_label": true,
            "param_specs": [
                {
                    "alias": "P",
                    "custom": true,
                    "descr": "",
                    "dim": "none",
                    "label": "P",
                    "name": "Dioptric power"
                },
                {
                    "alias": "alpha",
                    "custom": true,
                    "descr": "",
                    "dim": "angular",
                    "label": "alpha",
                    "name": "Tilt angle"
                }
            ],
            "params": {
                "P": {
                    "error": "",
                    "expr": "20",
                    "unit": "none",
                    "value": 20
                },
                "alpha": {
                    "error": "",
                    "expr": "5",
                    "unit": "deg",
                    "value": 5
                }
            },
            "title": "",
            "type": "ElemFormula",
            "type_name": "Dioptric lens"
        },
        {
            "is_disabled": false,
            "label": "L",
            "layout_draw_alt": false,
            "layout_show_label": true,
            "params": {
                "L": {
                    "error": "",
                    "expr": "",
                    "unit": "mm",
                    "value": 420
                },
                "n": {
                    "error": "",
                    "expr": "",
                    "unit": "none",
                    "value": 1
                }
            },
            "title": "Folding range",
            "type": "ElemEmptyRange"
        },
        {
